# Required for the /consultation form to actually send email.
# 1. Create a free account at https://resend.com
# 2. Verify your sending domain (cliqworx.co.za) under Domains, or use the
#    default onboarding@resend.dev sender for testing before DNS is set up.
# 3. Create an API key under API Keys and paste it below.
RESEND_API_KEY=

# Where consultation requests are delivered. Defaults to hello@cliqworx.com if unset.
CONSULTATION_TO_EMAIL=hello@cliqworx.com

# The "from" address Resend sends as. Must be on a domain you've verified in
# Resend, e.g. "CliqWorx Website <hello@cliqworx.co.za>". Defaults to Resend's
# shared onboarding@resend.dev sender, which works without domain verification
# but is only suitable for testing, not production.
CONSULTATION_FROM_EMAIL=
